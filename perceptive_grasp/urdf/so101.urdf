  SO-101 Robot Arm URDF (simplified, no mesh dependencies)

  基于 TheRobotStudio/SO-ARM100 项目的 so101_new_calib.urdf 简化而来。
  原始文件: https://github.com/TheRobotStudio/SO-ARM100/blob/main/Simulation/SO101/so101_new_calib.urdf

  简化内容:
    - 去掉了 STL mesh, 使用简单几何体 (圆柱/盒体) 替代
    - 保留了完整的运动学参数 (关节原点、轴向、限位)
    - 保留了惯性参数 (质量、惯性矩阵)
    - 运动链: base_link → shoulder_link → upper_arm_link → lower_arm_link
              → wrist_link → gripper_link → gripper_frame_link (固定)

  关节对应关系:
    joint1 = shoulder_pan   (motor ID 1, yaw)
    joint2 = shoulder_lift  (motor ID 2, pitch)
    joint3 = elbow_flex     (motor ID 3, pitch)
    joint4 = wrist_flex     (motor ID 4, pitch)
    joint5 = wrist_roll     (motor ID 5, roll)
    joint6 = gripper        (motor ID 6, 夹爪)

  注意:
    - 运动学链的 IK 终点建议使用 "gripper_frame_link" (固定 TCP 偏移)
    - 如果仅需 5-DOF IK (不含夹爪), 使用 "gripper_link" 作为 tip
-->
<robot name="so101">

  <!-- Materials -->
  <material name="3d_printed">
    <color rgba="1.0 0.82 0.12 1.0"/>
  </material>
  <material name="sts3215">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- ====================================================================
       Link: base_link
       ==================================================================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0137179 -5.19711e-05 0.0334843" rpy="0 0 0"/>
      <mass value="0.147"/>
      <inertia ixx="0.000114686" ixy="-4.59787e-07"
               ixz="4.97151e-06" iyy="0.000136117"
               iyz="9.75275e-08" izz="0.000130364"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.04"/>
      </geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.04"/>
      </geometry>
    </collision>
  </link>

  <!-- ====================================================================
       Joint: shoulder_pan (motor 1, base → shoulder, yaw rotation)
       ==================================================================== -->
  <joint name="shoulder_pan" type="revolute">
    <origin xyz="0.0388353 -8.97657e-09 0.0624" rpy="3.14159 4.18253e-17 -3.14159"/>
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.91986" upper="1.91986"/>
  </joint>

  <transmission name="shoulder_pan_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="shoulder_pan">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor1">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- ====================================================================
       Link: shoulder_link
       ==================================================================== -->
  <link name="shoulder_link">
    <inertial>
      <origin xyz="-0.0307604 -1.66727e-05 -0.0252713" rpy="0 0 0"/>
      <mass value="0.100006"/>
      <inertia ixx="8.3759e-05" ixy="7.55525e-08"
               ixz="-1.16342e-06" iyy="8.10403e-05"
               iyz="1.54663e-07" izz="2.39783e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.03 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.07 0.04 0.06"/>
      </geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="-0.03 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.07 0.04 0.06"/>
      </geometry>
    </collision>
  </link>

  <!-- ====================================================================
       Joint: shoulder_lift (motor 2, shoulder → upper_arm, pitch)
       ==================================================================== -->
  <joint name="shoulder_lift" type="revolute">
    <origin xyz="-0.0303992 -0.0182778 -0.0542" rpy="-1.5708 -1.5708 0"/>
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.74533" upper="1.74533"/>
  </joint>

  <transmission name="shoulder_lift_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="shoulder_lift">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor2">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- ====================================================================
       Link: upper_arm_link (大臂, ~11.3cm)
       ==================================================================== -->
  <link name="upper_arm_link">
    <inertial>
      <origin xyz="-0.0898471 -0.00838224 0.0184089" rpy="0 0 0"/>
      <mass value="0.103"/>
      <inertia ixx="4.08002e-05" ixy="-1.97819e-05"
               ixz="-4.03016e-08" iyy="0.000147318"
               iyz="8.97326e-09" izz="0.000142487"/>
    </inertial>
    <visual>
      <origin xyz="-0.056 0 0.018" rpy="0 0 0"/>
      <geometry>
        <box size="0.113 0.03 0.03"/>
      </geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.056 0 0.018" rpy="0 0 0"/>
      <geometry>
        <box size="0.113 0.03 0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- ====================================================================
       Joint: elbow_flex (motor 3, upper_arm → lower_arm, pitch)
       ==================================================================== -->
  <joint name="elbow_flex" type="revolute">
    <origin xyz="-0.11257 -0.028 1.73763e-16" rpy="-3.63608e-16 8.74301e-16 1.5708"/>
    <parent link="upper_arm_link"/>
    <child link="lower_arm_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.69" upper="1.69"/>
  </joint>

  <transmission name="elbow_flex_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="elbow_flex">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor3">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- ====================================================================
       Link: lower_arm_link (小臂, ~13.5cm)
       ==================================================================== -->
  <link name="lower_arm_link">
    <inertial>
      <origin xyz="-0.0980701 0.00324376 0.0182831" rpy="0 0 0"/>
      <mass value="0.104"/>
      <inertia ixx="2.87438e-05" ixy="7.41152e-06"
               ixz="1.26409e-06" iyy="0.000159844"
               iyz="-4.90188e-08" izz="0.00014529"/>
    </inertial>
    <visual>
      <origin xyz="-0.067 0 0.018" rpy="0 0 0"/>
      <geometry>
        <box size="0.135 0.03 0.03"/>
      </geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="-0.067 0 0.018" rpy="0 0 0"/>
      <geometry>
        <box size="0.135 0.03 0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- ====================================================================
       Joint: wrist_flex (motor 4, lower_arm → wrist, pitch)
       ==================================================================== -->
  <joint name="wrist_flex" type="revolute">
    <origin xyz="-0.1349 0.0052 3.62355e-17" rpy="4.02456e-15 8.67362e-16 -1.5708"/>
    <parent link="lower_arm_link"/>
    <child link="wrist_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.65806" upper="1.65806"/>
  </joint>

  <transmission name="wrist_flex_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wrist_flex">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor4">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- ====================================================================
       Link: wrist_link
       ==================================================================== -->
  <link name="wrist_link">
    <inertial>
      <origin xyz="-0.000103312 -0.0386143 0.0281156" rpy="0 0 0"/>
      <mass value="0.079"/>
      <inertia ixx="3.68263e-05" ixy="1.7893e-08"
               ixz="-5.28128e-08" iyy="2.5391e-05"
               iyz="3.6412e-06" izz="2.1e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.03 0.018" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.06 0.03"/>
      </geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="0 -0.03 0.018" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.06 0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- ====================================================================
       Joint: wrist_roll (motor 5, wrist → gripper, roll)
       ==================================================================== -->
  <joint name="wrist_roll" type="revolute">
    <origin xyz="5.55112e-17 -0.0611 0.0181" rpy="1.5708 0.0486795 3.14159"/>
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-2.74385" upper="2.84121"/>
  </joint>

  <transmission name="wrist_roll_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="wrist_roll">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor5">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- ====================================================================
       Link: gripper_link
       ==================================================================== -->
  <link name="gripper_link">
    <inertial>
      <origin xyz="0.000213627 0.000245138 -0.025187" rpy="0 0 0"/>
      <mass value="0.087"/>
      <inertia ixx="2.75087e-05" ixy="-3.35241e-07"
               ixz="-5.7352e-06" iyy="4.33657e-05"
               iyz="-5.17847e-08" izz="3.45059e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.08"/>
      </geometry>
      <material name="sts3215"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.08"/>
      </geometry>
    </collision>
  </link>

  <!-- ====================================================================
       Joint: gripper (motor 6, gripper → moving_jaw, 夹爪)
       ==================================================================== -->
  <joint name="gripper" type="revolute">
    <origin xyz="0.0202 0.0188 -0.0234" rpy="1.5708 -5.24284e-08 -1.41553e-15"/>
    <parent link="gripper_link"/>
    <child link="moving_jaw_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-0.174533" upper="1.74533"/>
  </joint>

  <transmission name="gripper_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="gripper">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="motor6">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- ====================================================================
       Link: moving_jaw_link (夹爪活动部)
       ==================================================================== -->
  <link name="moving_jaw_link">
    <inertial>
      <origin xyz="-0.00157495 -0.0300244 0.0192755" rpy="0 0 0"/>
      <mass value="0.012"/>
      <inertia ixx="6.61427e-06" ixy="-3.19807e-07"
               ixz="-5.90717e-09" iyy="1.89032e-06"
               iyz="-1.09945e-07" izz="5.28738e-06"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.025 0.019" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.05 0.03"/>
      </geometry>
      <material name="3d_printed"/>
    </visual>
    <collision>
      <origin xyz="0 -0.025 0.019" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.05 0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- ====================================================================
       Link: gripper_frame_link (末端坐标系, 固定偏移)

       这是 IK 的末端参考点 (TCP)
       从 gripper_link 固定偏移约 9.8cm, 绕 Y 旋转 180°
       ==================================================================== -->
  <link name="gripper_frame_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1e-9"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
  </link>

  <joint name="gripper_frame_joint" type="fixed">
    <origin xyz="-0.0079 -0.000218121 -0.0981274" rpy="0 3.14159 0"/>
    <parent link="gripper_link"/>
    <child link="gripper_frame_link"/>
    <axis xyz="0 0 0"/>
  </joint>

</robot>
